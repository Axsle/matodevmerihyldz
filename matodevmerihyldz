<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PSO ile Enerji Santrali Optimizasyonu</title>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; padding: 20px; }
        .container { max-width: 900px; margin: auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        h1, h3 { color: #2c3e50; }
        .input-group { margin-bottom: 15px; }
        input { padding: 8px; margin-right: 10px; border: 1px solid #ccc; border-radius: 4px; width: 80px; }
        button { padding: 10px 20px; background-color: #27ae60; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; margin-right: 5px; }
        button:hover { background-color: #2ecc71; }
        .btn-pso { background-color: #8e44ad; }
        .btn-pso:hover { background-color: #9b59b6; }
        #result { margin-top: 20px; font-weight: bold; color: #8e44ad; font-size: 18px;}
        #plot { width: 100%; height: 500px; margin-top: 20px; }
    </style>
</head>
<body>

<div class="container">
    <h1>PSO Tabanlı Santral Optimizasyonu</h1>
    <p>Sistem, en iyi konumu bulmak için <b>Parçacık Sürü Optimizasyonu </b> kullanır. Şehirleri girin ve PSO'yu başlatın.</p>
    
    <div id="cities-inputs">
        <div class="input-group">
            Şehir 1: <input type="number" class="x-val" placeholder="X" value="10"> 
            <input type="number" class="y-val" placeholder="Y" value="20"> 
            <input type="number" class="w-val" placeholder="Talep" value="50"> MW
        </div>
        <div class="input-group">
            Şehir 2: <input type="number" class="x-val" placeholder="X" value="40"> 
            <input type="number" class="y-val" placeholder="Y" value="80"> 
            <input type="number" class="w-val" placeholder="Talep" value="120"> MW
        </div>
        <div class="input-group">
            Şehir 3: <input type="number" class="x-val" placeholder="X" value="70"> 
            <input type="number" class="y-val" placeholder="Y" value="30"> 
            <input type="number" class="w-val" placeholder="Talep" value="80"> MW
        </div>
    </div>
    
    <button onclick="addCity()">+ Yeni Şehir Ekle</button>
    <button class="btn-pso" onclick="runPSO()">Sürüyü Çalıştır (PSO Hesapla)</button>

    <div id="result"></div>
    <div id="plot"></div>
</div>

<script>
    let cityCount = 3;

    function addCity() {
        cityCount++;
        const div = document.createElement('div');
        div.className = 'input-group';
        div.innerHTML = `Şehir ${cityCount}: <input type="number" class="x-val" placeholder="X" value="0"> 
                         <input type="number" class="y-val" placeholder="Y" value="0"> 
                         <input type="number" class="w-val" placeholder="Talep" value="0"> MW`;
        document.getElementById('cities-inputs').appendChild(div);
    }

    // Maliyet (Cost) Fonksiyonu: Gerçek mesafe * Talep
    function calculateCost(x, y, cities) {
        let totalCost = 0;
        for(let city of cities) {
            let distance = Math.sqrt(Math.pow(x - city.x, 2) + Math.pow(y - city.y, 2));
            totalCost += distance * city.w;
        }
        return totalCost;
    }

    function runPSO() {
        const xInputs = document.querySelectorAll('.x-val');
        const yInputs = document.querySelectorAll('.y-val');
        const wInputs = document.querySelectorAll('.w-val');

        let cities = [];
        let xCoords = [], yCoords = [], labels = [], sizes = [];

        for (let i = 0; i < xInputs.length; i++) {
            let x = parseFloat(xInputs[i].value);
            let y = parseFloat(yInputs[i].value);
            let w = parseFloat(wInputs[i].value);
            
            cities.push({x: x, y: y, w: w});
            xCoords.push(x); yCoords.push(y);
            labels.push(`Şehir ${i+1} (${w} MW)`);
            sizes.push(Math.max(w / 3, 10));
        }

        // --- PSO ALGORİTMASI BAŞLANGICI ---
        const numParticles = 30; // 30 farklı noktada arama yapacağız
        const maxIter = 100; // 100 adım boyunca iyileştirme
        const w_inertia = 0.7; // Atalet ağırlığı
        const c1 = 1.5; // Bilişsel katsayı (Kişisel hafıza)
        const c2 = 1.5; // Sosyal katsayı (Sürü hafızası)

        let particles = [];
        let gBest = { x: 0, y: 0, cost: Infinity };

        // 1. Aşama: Parçacıkları rastgele başlat
        for(let i=0; i<numParticles; i++) {
            let p = {
                x: Math.random() * 100,
                y: Math.random() * 100,
                vx: (Math.random() - 0.5) * 10,
                vy: (Math.random() - 0.5) * 10,
                pBest: { x: 0, y: 0, cost: Infinity }
            };
            
            let currentCost = calculateCost(p.x, p.y, cities);
            p.pBest.x = p.x; p.pBest.y = p.y; p.pBest.cost = currentCost;

            if(currentCost < gBest.cost) {
                gBest.x = p.x; gBest.y = p.y; gBest.cost = currentCost;
            }
            particles.push(p);
        }

        // 2. Aşama: Sürüyü hareket ettir (Optimizasyon Döngüsü)
        for(let iter=0; iter<maxIter; iter++) {
            for(let p of particles) {
                let r1 = Math.random();
                let r2 = Math.random();

                // Hız Güncelleme
                p.vx = w_inertia * p.vx + c1 * r1 * (p.pBest.x - p.x) + c2 * r2 * (gBest.x - p.x);
                p.vy = w_inertia * p.vy + c1 * r1 * (p.pBest.y - p.y) + c2 * r2 * (gBest.y - p.y);

                // Konum Güncelleme
                p.x += p.vx;
                p.y += p.vy;

                // Harita sınırları dışına çıkmasını engelle
                p.x = Math.max(0, Math.min(100, p.x));
                p.y = Math.max(0, Math.min(100, p.y));

                // Yeni konumu değerlendir
                let newCost = calculateCost(p.x, p.y, cities);
                if(newCost < p.pBest.cost) {
                    p.pBest.x = p.x; p.pBest.y = p.y; p.pBest.cost = newCost;
                    
                    if(newCost < gBest.cost) {
                        gBest.x = p.x; gBest.y = p.y; gBest.cost = newCost;
                    }
                }
            }
        }
        // --- PSO ALGORİTMASI BİTİŞİ ---

        document.getElementById('result').innerText = `PSO'nun Bulduğu Optimum Santral Konumu: X = ${gBest.x.toFixed(2)}, Y = ${gBest.y.toFixed(2)} \n(Minimum Maliyet: ${gBest.cost.toFixed(2)})`;

        drawPlot(xCoords, yCoords, labels, sizes, gBest.x, gBest.y);
    }

    function drawPlot(x, y, labels, sizes, optX, optY) {
        var traceCities = {
            x: x, y: y, mode: 'markers+text', type: 'scatter',
            name: 'Şehirler (Talep)', text: labels, textposition: 'top center',
            marker: { size: sizes, color: '#3498db', opacity: 0.7 }
        };

        var tracePlant = {
            x: [optX], y: [optY], mode: 'markers+text', type: 'scatter',
            name: 'Optimum Santral (PSO)', text: ['Santral Konumu'], textposition: 'bottom center',
            marker: { size: 25, color: '#8e44ad', symbol: 'star' }
        };

        var layout = {
            title: 'Yapay Zeka (PSO) ile Bulunan Optimum Santral Konumu',
            xaxis: { title: 'X Koordinatı', range: [0, 100] },
            yaxis: { title: 'Y Koordinatı', range: [0, 100] },
            showlegend: true
        };

        Plotly.newPlot('plot', [traceCities, tracePlant], layout);
    }

    runPSO();
</script>

</body>
</html>
